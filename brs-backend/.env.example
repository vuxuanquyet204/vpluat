# ============================================================
# BRS Backend Environment Variables (Development)
# ============================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=brs_dev
DB_USER=brs_dev
DB_PASSWORD=brs_dev_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT Keys
JWT_PRIVATE_KEY_PATH=keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt-public.pem

# CORS Origins
CORS_ORIGIN_1=http://localhost:3000
CORS_ORIGIN_2=http://localhost:5173

# Application
APP_HOST=0.0.0.0
APP_PORT=8080

# Logging
LOG_LEVEL=INFO
