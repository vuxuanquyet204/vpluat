# ============================================================
# BRS Backend Environment Variables (Development)
# ============================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=brs_db
DB_USER=postgres
DB_PASSWORD=password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT Keys
JWT_PRIVATE_KEY_PATH=keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt-public.pem

# CORS Origins
CORS_ORIGIN_1=http://localhost:3000
CORS_ORIGIN_2=http://localhost:5173
CORS_ORIGIN_3=https://lawfirm.vn
CORS_ORIGIN_4=https://www.lawfirm.vn

# Application
APP_HOST=0.0.0.0
APP_PORT=8080

# Webhook
WEBHOOK_SECRET=change-this-in-production

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
